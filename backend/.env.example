# Copy this file to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
# Local development — SQLite, no setup needed
DATABASE_URL=sqlite:///./dev.db
# Production — uncomment and fill in your PostgreSQL URL
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ── Auth (required) ───────────────────────────────────────────────────────────
# Any long random string — generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-secret-key-here

# ── External APIs (optional — static fallback data used if missing) ───────────
# Free key from https://newsdata.io — used for crypto news
NEWSDATA_API_KEY=

# Free key from https://openrouter.ai — used for AI insight (Gemma 3 12B)
OPENROUTER_API_KEY=

# ── Deployment (optional) ─────────────────────────────────────────────────────
# Your frontend URL — added to CORS allowed origins in production
FRONTEND_URL=
